{
  "name": "pi-zerg-swarm",
  "version": "0.1.0",
  "description": "Bootstrap scaffold for a Pi coding-agent extension that will coordinate high-capacity agentic teams.",
  "type": "module",
  "license": "MIT",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "internal-patch.ts",
    "parse.ts",
    "render.ts",
    "state.ts",
    "types.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
